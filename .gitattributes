# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Web
*.html text diff=html eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.xml text eol=lf

# Docs
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Config
*.cfg text eol=lf
*.conf text eol=lf
*.ini text eol=lf
*.toml text eol=lf

# Binary files - treat as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.exe binary
*.dll binary
*.pyc binary
*.wav binary
*.avi binary
*.mp3 binary
*.mp4 binary
*.lnk binary
*.db binary
*.sqlite binary

# Linguist overrides
*.bat linguist-language=batchfile
*.ps1 linguist-language=powershell
*.cmd linguist-language=batchfile
